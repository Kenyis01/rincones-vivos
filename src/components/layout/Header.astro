---
// Header del sitio. Reemplazar nav y logo con los del cliente.
const navLinks = [
  { href: "/", label: "Inicio" },
  // Agregar páginas a medida que existan (ver client-brief.md).
];
---

<header class="border-b border-border bg-surface">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="font-display text-xl text-brand">Nombre del cliente</a>
    <nav aria-label="Navegación principal">
      <ul class="flex gap-6">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-ink-muted hover:text-brand">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
